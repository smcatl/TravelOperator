---
import Base from '../layouts/Base.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { site } from '../config/site';

const featuredRoutes = [
  {
    no: '001',
    tag: 'Booking Engine',
    title: 'Rezdy 2026 — Field Review',
    excerpt: 'Our team operates Rezdy across multiple multi-day tour businesses. The channel manager carries serious weight; the reporting still needs route-correction.',
    href: '/reviews/rezdy-review-2026',
    readTime: '14 min',
  },
  {
    no: '002',
    tag: 'Booking Engine',
    title: 'FareHarbor — What Holds Up at Scale',
    excerpt: 'The conversion engine FareHarbor builds for partners is best-in-class. The trade-off is rate-card lock-in. We map where it fits — and where it does not.',
    href: '/reviews/fareharbor-review-2026',
    readTime: '12 min',
  },
  {
    no: '003',
    tag: 'Guide',
    title: 'The Travel Operator Tech Stack',
    excerpt: 'Six categories — booking, channel, waivers, payments, CX, ops — and the platforms that work for tour operators running ten or more departures a day.',
    href: '/guides/best-travel-tech-stack-2026',
    readTime: '13 min',
  },
];

const bearings = [
  {
    glyph: 'N',
    title: 'Field-tested routes',
    body: 'Every review comes from operators who have run actual departures on the platform — not from a demo seat or vendor onboarding call.',
  },
  {
    glyph: 'E',
    title: 'Scale-specific',
    body: 'Tools that work at 2 tours a day collapse at 20. We measure where each platform breaks — and which adjacent system has to absorb the load.',
  },
  {
    glyph: 'S',
    title: 'Full pricing transparency',
    body: 'Per-booking fees, channel-cost passthrough, payment processing markup — surfaced explicitly so the rate card stops being a surprise.',
  },
];
---
<Base title={site.name} description={site.description}>

  <!-- HERO — atlas cover -->
  <section class="hero">
    <div class="hero-grid-overlay"></div>
    <div class="hero-inner container">
      <div class="hero-content">
        <div class="hero-badge" style="letter-spacing:0.18em; text-transform:uppercase;">
          · Charted by tour operators ·
        </div>
        <h1>The atlas of software <em>that ships every departure</em></h1>
        <p class="hero-sub">
          Independent reviews of booking engines, channel managers, waiver tools, and the rest
          of the stack behind operators running tours, activities, and multi-day itineraries.
        </p>
        <div class="hero-actions">
          <a href="/reviews" class="btn btn-teal btn-lg">Open the Atlas →</a>
          <a href="/guides/best-travel-tech-stack-2026" class="btn btn-outline btn-lg" style="color:#FFFFFF; border-color:rgba(255,255,255,.6); background:rgba(255,255,255,.08);">The Tech Stack</a>
        </div>
      </div>

      <div class="hero-stat-card">
        <div class="hero-stats">
          <div class="stat-item">
            <span class="stat-number">8<em>+</em></span>
            <span class="stat-label">Platforms charted</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-number">Multi-Day</span>
            <span class="stat-label">Operator focus</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-number">Independent</span>
            <span class="stat-label">Editorial heading</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-number">2026</span>
            <span class="stat-label">Atlas edition</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURED ROUTES -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="section-label">Featured Routes</p>
        <h2 class="section-title">This edition's primary headings</h2>
        <p class="section-sub" style="font-family:'Bebas Neue',sans-serif; letter-spacing:0.12em; opacity:0.78; max-width:42rem; margin-top:0.75rem;">
          Three platforms reviewed end-to-end — tested against the operational realities of multi-departure tour businesses.
        </p>
      </div>

      <div class="card-grid">
        {featuredRoutes.map(route => (
          <a href={route.href} class="post-card">
            <div class="post-card-body">
              <div style="display:flex; align-items:baseline; gap:0.85rem; margin-bottom:0.6rem;">
                <span style="font-family:'Bebas Neue',sans-serif; color:#9d76e8; font-size:0.85rem; letter-spacing:0.22em; text-transform:uppercase;">Route {route.no}</span>
                <span class="post-card-tag">{route.tag}</span>
              </div>
              <h3 style="font-family:'Bebas Neue',sans-serif; text-transform:uppercase; letter-spacing:0.02em;">{route.title}</h3>
              <p>{route.excerpt}</p>
              <div class="post-card-meta">
                <span style="text-transform:uppercase; letter-spacing:0.1em;">Reading</span>
                <span>·</span>
                <span>{route.readTime}</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div style="text-align:center; margin-top:2.5rem;">
        <a href="/reviews" class="btn btn-outline">Open the Full Atlas →</a>
      </div>
    </div>
  </section>

  <!-- BEARINGS -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <p class="section-label">Bearings</p>
        <h2 class="section-title">How {site.name} is charted</h2>
      </div>

      <div class="feature-grid">
        {bearings.map(b => (
          <div class="feature-item">
            <div style="font-family:'Bebas Neue',sans-serif; color:#9d76e8; font-size:1.6rem; letter-spacing:0.2em; margin-bottom:0.6rem; text-shadow:0 0 12px rgba(124, 79, 212, 0.35);">· {b.glyph} ·</div>
            <h3 style="font-family:'Bebas Neue',sans-serif; text-transform:uppercase; letter-spacing:0.04em;">{b.title}</h3>
            <p>{b.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="container" style="padding:clamp(1.5rem,4vw,2rem) clamp(1rem,4vw,1.5rem) clamp(2.5rem,6vw,4rem);">
    <NewsletterSignup
      variant="hero"
      title={`The ${site.name} dispatch`}
      description="One weekly heading — new routes added to the atlas, with field notes. No spam."
      ctaLabel="Subscribe"
    />
  </section>

</Base>
