---
import Base from '../layouts/Base.astro';
import { site } from '../config/site';
---
<Base title={`About ${site.name}`} description={`${site.name} is an editorially independent review site for ${site.niche}. Reviews drawn from a team with thousands of deployments across their combined network.`}>
  <div style="max-width:740px; margin:0 auto; padding:5rem 2rem;">
    <p class="section-label">About this site</p>
    <h1 style="font-family:'Syne',sans-serif; font-size:clamp(2rem,4vw,3rem); font-weight:800; color:var(--navy); margin-bottom:1.5rem; letter-spacing:-0.03em; line-height:1.1;">
      Software reviews from operators who actually deploy it
    </h1>
    <p>
      {site.tagline}
    </p>
    <p>
      The {site.name} team has thousands of deployments across their combined network and careers in {site.niche}. Every review is based on real operational experience — not vendor demos, not free trials, not press kits.
    </p>
    <h2>Editorial standards</h2>
    <p>
      {site.name} is editorially independent. Rankings are never for sale. The {site.name} team evaluates every tool on operational merit — verdicts reflect what actually performs, not vendor relationships.
    </p>
  </div>
</Base>
