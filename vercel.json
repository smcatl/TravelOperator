{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "astro",
  "redirects": [
    {
      "source": "/recommends/rezdy",
      "destination": "https://www.rezdy.com/",
      "permanent": false
    },
    {
      "source": "/recommends/fareharbor",
      "destination": "https://fareharbor.com/",
      "permanent": false
    },
    {
      "source": "/recommends/checkfront",
      "destination": "https://www.checkfront.com/",
      "permanent": false
    },
    {
      "source": "/recommends/peekpro",
      "destination": "https://www.peek.com/pro",
      "permanent": false
    },
    {
      "source": "/recommends/xola",
      "destination": "https://www.xola.com/",
      "permanent": false
    },
    {
      "source": "/recommends/safetywing",
      "destination": "https://safetywing.com/",
      "permanent": false
    },
    {
      "source": "/recommends/regiondo",
      "destination": "https://www.regiondo.com/",
      "permanent": false
    },
    {
      "source": "/recommends/smartwaiver",
      "destination": "https://www.smartwaiver.com/",
      "permanent": false
    },
    {
      "source": "/recommends/gohighlevel",
      "destination": "https://www.gohighlevel.com/?fp_ref=stosh61",
      "permanent": false
    },
    {
      "source": "/recommends/bokun",
      "destination": "https://www.bokun.io/",
      "permanent": false
    },
    {
      "source": "/recommends/waiverforever",
      "destination": "https://www.waiverforever.com/",
      "permanent": false
    },
    {
      "source": "/recommends/viator",
      "destination": "https://www.viator.com/",
      "permanent": false
    }
  ],
  "crons": [
    {
      "path": "/api/publish-next",
      "schedule": "0 11 * * 1"
    },
    {
      "path": "/api/publish-next",
      "schedule": "0 11 * * 2"
    },
    {
      "path": "/api/publish-next",
      "schedule": "0 11 * * 3"
    },
    {
      "path": "/api/publish-next",
      "schedule": "0 11 * * 4"
    },
    {
      "path": "/api/refill-queue",
      "schedule": "0 13 * * 0"
    }
  ]
}
